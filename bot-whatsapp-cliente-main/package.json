{
  "name": "bot",
  "version": "1.0.0",
  "description": "Bot de WhatsApp com painel desktop",
  "main": "dist/desktop/main.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "desktop:dev": "concurrently -k \"npm:renderer:dev\" \"npm:electron:dev\"",
    "renderer:dev": "vite --host 127.0.0.1",
    "electron:dev": "npm run build:main && wait-on http://127.0.0.1:5173 && cross-env ELECTRON_DISABLE_SECURITY_WARNINGS=true LIBGL_ALWAYS_SOFTWARE=1 electron . --disable-gpu --disable-gpu-compositing --disable-features=Vulkan,VulkanFromANGLE,DefaultANGLEVulkan",
    "build": "tsc && vite build",
    "build:main": "tsc",
    "desktop:build": "npm run build && electron-builder --win",
    "desktop:pack": "npm run build && electron-builder --dir"
  },
  "build": {
    "appId": "com.botwhatsapp.desktop",
    "productName": "Bot WhatsApp",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "6.7.18",
    "pino": "^9.0.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "vite": "^5.4.21",
    "wait-on": "^7.2.0"
  }
}
